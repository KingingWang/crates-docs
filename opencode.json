{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "custom-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Custom OpenAI Provider",
      "options": {
        "baseURL": "{env:OPENAI_BASE_URL}"
      },
      "models": {
        "{env:OPENAI_MODEL_NAME}": {
          "name": "Custom Model"
        }
      }
    }
  }
}
